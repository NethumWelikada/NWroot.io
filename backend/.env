# ============================================================
# NWroot.io - Environment Configuration
# ============================================================
# NOTE: This file ships with working default credentials so the
# project runs immediately after cloning, for local/staging use.
# If you deploy this publicly or to production, CHANGE these
# values (DB password, JWT_SECRET) before going live.
# ============================================================

# Application Configuration
APP_NAME="NWroot.io"
APP_ENV=staging
APP_DEBUG=true
APP_DEVELOPER="Nethum Welikada"

# --- STAGING ---
APP_URL=http://192.168.1.131:8080

# --- PRODUCTION ---
# When promoting to production: comment the STAGING line above
# and uncomment the line below with your real production URL.
#APP_URL=XXXXXXXXXX

# Timezone
TIMEZONE=Asia/Colombo

# Server port the Node backend listens on internally (Apache proxies to this)
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nwroot_db
DB_USER=nwrootu
DB_PASSWORD=nwrootu12
DB_CHARSET=utf8mb4

# JWT Auth Secret (change this to a long random string before any public deployment)
JWT_SECRET=nwroot_dev_secret_change_before_production
JWT_EXPIRES_IN=7d

# Docker sandbox settings
SANDBOX_IMAGE_NAME=nwroot-sandbox
SANDBOX_IDLE_TIMEOUT_MINUTES=30
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_LIMIT_MB=1024
