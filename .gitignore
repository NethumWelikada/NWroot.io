# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Note: backend/.env is intentionally NOT ignored in this project.
# Default working credentials are committed so the repo runs
# immediately after cloning. Change credentials before any
# public/production deployment.
frontend/.env.staging.local
frontend/.env.production.local

# Build output
frontend/dist/
backend/dist/

# Logs
*.log
npm-debug.log*
pm2.log

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp

# Docker
backend/docker/sandbox-image/*.tar